# apply default env
if [ -f ${HOME}/.default_env ]; then
    source ${HOME}/.default_env
fi

# if [ -z "${OLDPWD}" ]; then
    if [[ ! -z ${SSH_CLIENT} ]]; then 
        # in the case of opened by on the SSH client
        if [[ ! -z ${LC_WORKSPACE_PROJECT} && -d ${WORKSPACE_ROOT}/1.Projects/${LC_WORKSPACE_PROJECT} ]]; then
            workspace ${LC_WORKSPACE_PROJECT}
        fi
    else 
        # in the case of opened by on the local
        # same workspace project
        if [ ! -z ${WORKSPACE_PROJECT} ]; then 
            workspace ${WORKSPACE_PROJECT}
        # opened on the project directory in local
        elif [[ "${PWD}" == *"/workspace/1.Projects/"* ]]; then 
            _oldPwd=$(echo ${PWD} | sed 's/.*1\.Projects\///g');
            _workspace_name=$(echo ${_oldPwd} | cut -d"/" -f1)
            _oldSuffixPath=$(echo ${_oldPwd} | cut -d"/" -f2-)
            # echo "_oldPwd=${_oldPwd}"
            # echo "_workspace_name=${_workspace_name}"
            # echo "_oldSuffixPath=${_oldSuffixPath}"
            
            workspace ${_workspace_name}
            if [ -d ${_oldSuffixPath} ]; then
                cd ${_oldSuffixPath}
            fi
        fi
    fi
# fi