            log -d "workspace: set project_path=${project_path}"

            log -i "Environment of workspace set to \"${param}\""

            # 1. make workspace environment
            if [ ! -d ${project_path} ]; then
                log -i "Creating workspace for ${param} at ${project_path}"
                # create project path
                if [ -d ${WORKSPACE_ROOT}/1.Projects ]; then
                    log -d "workspace: create project_path=${project_path}"
                    mkdir -p ${project_path}
                    if [ -d ${WORKSPACE_ROOT}/bin/workspace_environment/${param} ]; then
                        log -d "workspace: link workspace environment to ${project_path}"
                        ln -s ${WORKSPACE_ROOT}/bin/workspace_environment/${param} ${project_path}/.workspace_env
                        ln -s ${project_path}/.workspace_env/bin/main.sh ${project_path}/workspace
                    fi
                else
                    log -w "not found the workspace root directory: ${WORKSPACE_ROOT}/1.Projects"
                    return 1
                fi
            fi

            
            
            # check symbol link or creating
