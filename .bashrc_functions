# update to an workspace
function workspace {
    local project_path="$WORKSPACE_ROOT/1.Projects/${WORKSPACE_PROJECT}"
    local param=${*: -1}
    
    log -d "workspace: project_path=${project_path}"
    log -d "workspace: WORKSPACE_PROJECT=${WORKSPACE_PROJECT}"
    log -d "workspace: param=${param}"
    log -d "workspace: params=$#"

    if [ $# = 0 ]; then
        if [ -z ${WORKSPACE_PROJECT} ]; then
            log -w "must need an project name!!!!"
        elif [ ! -f ${project_path}/workspace ]; then
            log -w "not found the ${project_path}/workspace"
        else
            ${project_path}/workspace;
        fi
    else
        if [ "-l" = "${param}" ]; then
            ls -c $WORKSPACE_ROOT/1.Projects/
        else
            project_path="$WORKSPACE_ROOT/1.Projects/${param}"
