# default setting
export WORKSPACE_PROJECT_TYPE="AAOS"
export BUILD_HOME="~/${WORKSPACE_PROJECT}"

if [ ${WORKSPACE_PROJECT} == "CONNECT_L" ]; then
    export WORKSPACE_PRODUCT_NAME="connect_l"
else
    export WORKSPACE_PRODUCT_NAME="connect_s"
fi
export WORKSPACE_BUILD_VARIANT="userdebug"
export WORKSPACE_BUILD_SERVER="svr"

if [ -d "${WORKSPACE_HOME}/lagvm/LINUX/android" ]; then
    
    export WORKSPACE_ANDROID_HOME="${WORKSPACE_HOME}/lagvm/LINUX/android"
    export JAVA_HOME=${WORKSPACE_HOME}/release/gradle/JDK/jbr/
    export ANDROID_HOME=${WORKSPACE_HOME}/release/gradle/SDK/
    export PATH=${JAVA_HOME}/bin:$PATH
    export PATH=$HOME/localperl/bin:$PATH
    export LAGVM_PRODUCT_NAME="${WORKSPACE_PRODUCT_NAME}:${LC_WS_PROD_NAME}"
    export LAGVM_BUILD_VARIANT="${WORKSPACE_BUILD_VARIANT}"
    

    export SKIP_ABI_CHECKS=true

    #RECOMPILE_KERNEL=1 ./kernel_platform/build/android/prepare_vendor.sh autogvm gki

    # ignore tests while on build
    export BUILD_BROKEN_TESTS=true
    export BUILD_BROKEN_INSTRUMENTATION_TESTS=true

    unalias workspace 2>/dev/null
    unset -f workspace 2>/dev/null

    alias go_android="cd $WORKSPACE_ANDROID_HOME"
    alias envsetup="cd $WORKSPACE_ANDROID_HOME && source build/envsetup.sh"

    function build_env {
        cd ${WORKSPACE_ANDROID_HOME}
        source build/envsetup.sh
        lunch ${LAGVM_PRODUCT_NAME}-${LAGVM_BUILD_VARIANT}
    }

else
    export WORKSPACE_PRODUCT_ALIAS="connect"
    export LC_WS_PROD_NAME="${WORKSPACE_PRODUCT_NAME}"
    export WORKSPACE_ADB_PERMISSIVE=false

    if [ "${WORKSPACE_PRODUCT_NAME}" == "connect_l" ] ; then
        export ANDROID_SERIAL="cfd42ac7"
    else
        export ANDROID_SERIAL="db1aec47"
    fi

    export ANDROID_OUTPUT="/mnt/w/${WORKSPACE_PROJECT}/lagvm/LINUX/android/out/target/product/${WORKSPACE_PRODUCT_NAME}"
    export ANDROID_PRODUCT_OUT="${ANDROID_OUTPUT}"
    export WORKSPACE_REMOTE_HOME="/mnt/w/${WORKSPACE_PROJECT}"
    export WORKSPACE_ADB_PERMISSIVE=false
    # export ANDROID_SERIAL="f2f2958a"
    # export ANDROID_SERIAL="db1aec47"
    
    
    if [ -f "${WORKSPACE_HOME}/.workspace_env/bin/fpm.sh" ]; then
        complete -W "$(${WORKSPACE_HOME}/.workspace_env/bin/car_prop.sh -l)" car_prop.sh
    fi

    if [ -f "${WORKSPACE_HOME}/.workspace_env/bin/xbuild_module.sh" ]; then
        complete -W "$(${WORKSPACE_HOME}/.workspace_env/bin/xbuild_module.sh -l)" xbuild_module.sh
    fi

    if [ -f "${WORKSPACE_HOME}/.workspace_env/bin/fpm.sh" ]; then
        complete -W "$(${WORKSPACE_HOME}/.workspace_env/bin/fpm.sh -l)" fpm.sh
    fi

    function adb_device_monitoring(){
        local serial="${1:-$ANDROID_SERIAL}"
        while true; do
            draw_line_with_title "Waiting for device" "-" ${COLOR_RED}
            adb_wait-for-device
            adb_connect -r
            adb_time_set
            if [ $? -eq 0 ]; then
                # adb_root;
                while ! car_prop.sh TCU_TYPE_AUTO > /dev/null 2>&1; do
                    sleep 1
                done
                log -i "TCU is ready, applying power state timers..."
                while ! do_execute -i "adb shell cmd mobispower command-apply-tad-sys-state-timer 1 0005" > /dev/null 2>&1; do
                    sleep 1
                done
                while ! do_execute -i "adb shell cmd mobispower command-apply-tad-sys-state-timer 2 0010" > /dev/null 2>&1; do
                    sleep 1
                done
                
                log -i "Power state timers applied successfully."
                # monitoring power state by adb shell dumpsys mobispower
                # adb logcat -b all | egrep mCarPowerStateListenerWithCompletion
                powerState=""
                # check with adb is connected
                while adb_is_connected; do
                    pState=$(adb shell dumpsys mobispower | grep "mState" | cut -d":" -f2 | tr -d ' ')
                    if [ "$pState" != "$powerState" ]; then

                        pStateReadable=$(
                            case $pState in
                                0)
                                    echo "STATE_NORMAL(0)"
                                    ;;
                                1)
                                    echo "STATE_WELCOME(1)"
                                    ;;
                                2)
                                    echo "STATE_ADM(2)"
                                    ;;
                                3)
                                    echo "STATE_WAIT_DOOR_OPEN(3)"
                                    ;;
                                4)
                                    echo "STATE_GOODBYE(4)"
                                    ;;
                                5)
                                    echo "STATE_LOGIC_OFF(5)"
                                    ;;
                                6)
                                    echo "STATE_RMT_ENG(6)"
                                    ;;
                                7)
                                    echo "STATE_PRE_SYSTEM_OFF(7)"
                                    ;;
                                8)
                                    echo "STATE_SYSTEM_OFF(8)"
                                    ;;
                                9)
                                    echo "STATE_POST_SYSTEM_OFF(9)"
                                    ;;
                                *)
                                    echo "unknown"
                                    ;;
                            esac
                        )                
                        log -i "Power state changed: $pStateReadable"
                        powerState="$pState"
                    fi
                    sleep 1
                done
            fi
            draw_line_with_title "Device is running" "-" ${COLOR_GREEN}
            adb wait-for-disconnect
        done
    }

    function adb_dump_fd_memory(){
        local serial="${1:-$ANDROID_SERIAL}"
    
        while true; do
            # draw_line_with_title "Waiting for device" "-" ${COLOR_RED}
            adb wait-for-device
            adb_connect -r
            adb shell sh /data/device_script_dump_fd_memory.sh
            log -w "Entered to STR? if so, Turn on STR and check the logcat for FD and DMABUF info"
            # echo turn off the STR mode after 30 seconds
        done
    }

    alias IGNITION_ON="adb shell dumpsys android.hardware.automotive.vehicle.IVehicle/default --set 557891584 -i 1"
fi
