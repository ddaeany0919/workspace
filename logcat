function connectToAdbDevice() {
    if $DEBUG; then
        log -d "$FUNCNAME: RECONNECT=$RECONNECT"
    fi

    # wait for device
    adb_wait-for-device
    do_execute -q adb_connect root
}

function clearBuffer() {
    if $DEBUG; then
        log -d "clearBuffer: targetDevice=$targetDevice"
    fi
    if ! adb_is_connected; then
        if ! connectToAdbDevice; then
            log -e "clearBuffer: Could not connect to adb device: ${ANDROID_SERIAL}"
            return 1
        fi
    fi

    do_execute -i "adb -s $targetDevice logcat -c -b all"
}

function makeFilterList() {
    local filter_values=""
    if [ -n "$filterList" ]; then
        filter_values=$filterList
    fi

    if [ $# -gt 0 ]; then
        for filter in "$@"; do
            if [ -z "$filter_values" ]; then
                filter_values="$filter"
            else
                filter_values="$filter_values|$filter"
            fi

        done
    fi

    if [ -n "$filter_values" ]; then
        filter_values="fatal|$filter_values"
        echo "$GREP_COMMAND -ia \"$filter_values\""
        return 0
    fi
    return 1
}

function makeInvertFilterList() {
    if [ -n "$invertFilterList" ]; then
        echo "$GREP_COMMAND -iav \"$invertFilterList\""
        return 0
    fi
    return 1;
}


function buildProcessFilter() {
    local usePidOf=true
    # get pid of process from PROCESS_PKG

    processFilterList=${PROCESS_RAW[@]}
    log -d "$FUNCNAME:\t process filter list=\"$processFilterList\""
    if [ -n "$processFilterList" ]; then
        if $usePidOf; then
            filter_process=$(do_execute -i "adb shell pidof \"$processFilterList\"")
            # check pid count
            pid_count=$(echo "$filter_process" | wc -w)
            if [ $pid_count -gt 1 ]; then
                log -w "Multiple PIDs found for package \"$processFilterList\": $filter_process. Monitoring all of them."
                # " | egrep \" pid1 | pid2\""
                local result=""
                for pid in $filter_process; do
                    if [ -z "$result" ]; then
                        result=" $pid "
                    else
                        result="$result| $pid "
                    fi
                    
                done
                result=" | egrep \"$result\""
                echo $result
            elif [ $pid_count -eq 0 ]; then
                log -w "No PID found for package \"$processFilterList\". Process might not be running. Please check the package name or ensure the app is running."
                echo ""
            else
                log -i "PID found for package \"$processFilterList\": $filter_process"
                IFS=' ' read -r -a filter_process <<<"$filter_process"
                # log -d "$FUNCNAME:\t filter_process array=\"${filter_process[@]}\""
                # make pid filter option (--pid=xxxx)
                local result="${filter_process[@]/#/--pid=}"
                echo "${filter_process[@]/#/--pid=}"
            fi
            
            
            # log -d "$FUNCNAME:\t LOGCAT_PROCESS_OPTION=\"$LOGCAT_PROCESS_OPTION\""
            
        else
            command="$command| $GREP_COMMAND \`adb shell ps -ef | $GREP_COMMAND $processFilterList | tr -s [:space:] ' ' | cut -d' ' -f2\`"
            log -d "$FUNCNAME: $command"
            echo "TODO: need to implement process name filter without pidof"
        fi
    fi
    echo "";
}


function printFromFile() {
    command=""
    local invertFilters=$(makeInvertFilterList)
    local filters=$(makeFilterList $@)

    if [ -n "${invertFilters}" ]; then
        command="${invertFilters} ${readFile}"
    fi

    if [ -n "${filters}" ]; then
        if [ -n "${command}" ]; then
            command="${command} | ${filters}"
        else 
            command="${filters} ${readFile}"
        fi
    fi

    if [ ! -n "${command}" ]; then
        command="cat ${readFile}"
    fi
    
}

