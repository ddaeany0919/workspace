#-----------------------------
# getopt 정의
#  - short : hVrdf:v:p:t:i:
#  - long  : help, root, profile:, reconnect, view, debug,
#            filter:, invert:, process:, tee:, input:
#-----------------------------
OPTS=$(getopt -o hcVrdf:v:p:t:i: \
  -l help,clean,root,profile:,reconnect,view,debug,filter:,invert:,process:,tee:,input: -- "$@") || {
  die "옵션 파싱 실패"
}
eval set -- "$OPTS"
#--------------------------------------------------
# 옵션 파싱
#--------------------------------------------------
while true; do
  case "$1" in
    -h|--help)      usage; exit 0 ;;
    --root)         ROOT=true; shift ;;
    --profile)      PROFILE="$2"; shift 2 ;;

    -c|--clean)     CLEAN=true; shift ;;
    -r|--reconnect) RECONNECT=true; shift ;;
    -V|--view)      VIEW=true; shift ;;
    -d|--debug)     DEBUG=true; shift ;;

    -f|--filter)    FILTER_RAW="$2"; shift 2 ;;
    -v|--invert)    INVERT_RAW="$2"; shift 2 ;;

    -p|--process)   PROCESS_RAW="$2"; shift 2 ;;
    -t|--tee)       TEE_FILE="$2"; shift 2 ;;
    -i|--input)     INPUT_FILE="$2";
                    if [ ! -f "${INPUT_FILE}" ]; then
                       log -w "${INPUT_FILE} is not exist!"
                       exit 1;
                    fi
                    shift 2 ;;

    --)             shift; break ;;
    *)              die "알 수 없는 옵션: $1" ;;
  esac
done

