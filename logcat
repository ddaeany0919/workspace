########################################################################################################################

function die() { echo "❌ $*" >&2; exit 1; }

function split_pipe() {  # "a|b|c" -> 배열에 push
  local s="${1:-}"
  [[ -z "$s" ]] && return 0
  IFS='|' read -r -a __arr <<<"$s"
  printf '%s\0' "${__arr[@]}"
}

function validate_taglist() { # 태그 유효성(원하면 규칙 바꿔도 됨)
  local s="${1:-}"
  [[ -z "$s" ]] && return 0
  # 허용: 영문/숫자/_/- 로 구성된 태그들을 '|' 로 연결
  [[ "$s" =~ ^[A-Za-z0-9_-]+(\|[A-Za-z0-9_-]+)*$ ]] || \
    die "잘못된 태그 목록입니다: '$s' (예: tag1|tag2)"
}

function usage() {
  cat <<'EOF'
Usage: script.sh [options]

Options:
  --root                      Run as root (flag)
  --profile <name>            Profile name (value)
  -h, --help                  Show help (flag)

  --reconnect, -r             Reconnect (flag)
  --view, -V                  View mode (flag)
  --debug, -d                 Enable debug (flag)

  --filter <tag1|tag2>, -f <tag1|tag2>
                              Filter tags (value, '|' 구분)
  --invert <tag1|tag2>, -v <tag1|tag2>
                              Invert tags (value, '|' 구분)

  --process <package>, -p <package>
                              Target package name (value)
  --tee <file>, -t <file>     Tee output file (value)
  --input <file>, -i <file>   Input file (value)

호출 예:
  ./script.sh --root --profile dev -r -V --filter "net|ui" --invert=beta \
    -p com.example.app -t out.log -i input.txt --debug
EOF
}

trap cleanup SIGINT
